
@article{crego_linking_2026,
	title = {Linking {eBird} data with high spatiotemporal remote sensing products to estimate occupancy of bird populations across the island of {Ireland}},
	issn = {0019-1019, 1474-919X},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/ibi.70048},
	doi = {10.1111/ibi.70048},
	abstract = {The vast increase in biodiversity data generated through citizen science initiatives, alongside a growing suite of remote sensing products and advanced modelling tools, has opened new avenues for rapidly, accurately and efficiently monitoring species trends to inform conservation, management and policy. However, fully harnessing and integrating these diverse data sources and models remains underexplored, with efforts often concentrated in a limited number of developed countries. In this study, we (1) summarized two decades of eBird data across the island of Ireland and (2) combined 4 years of data with high‐spatiotemporal‐resolution remotely sensed information and Bayesian hierarchical occupancy models, to assess species occupancy and identify environmental drivers of occupancy, accounting for imperfect detection. We applied a single‐species multi‐year occupancy model to the Common Blackbird
              Turdus merula
              and a multi‐species multi‐year model to 14 species, validating model predictions using a systematic bird survey. Results show an exponential increase in eBird checklist submissions across the island of Ireland between 2002 and 2023. The single species model fitted the data well and accounted for several observation biases, and occupancy predictions resulted in high accuracy with an area under the curve or the receiver operating characteristic (AUC‐ROC) of 95.6\% across years. The multi‐species model presented lack‐of‐fit, and model prediction accuracy varied across species and years: 14\% were poor (AUC‐ROC {\textless} 60\%), 34\% fair (AUC‐ROC 60–70\%) and 77\% good (AUC‐ROC {\textgreater} 70\%). Although more data are needed to improve fit in the multi‐species model and include rarer species in the analysis, our findings highlight the potential of integrating eBird citizen science data with high‐resolution remote sensing imagery to enhance current conservation, restoration and monitoring programmes. Assuming that citizen involvement and checklist submissions continue their current increasing trends, spatial and temporal data coverage will improve as well as model outputs. To guide this process, we offer guidelines for generating more ‘analysis‐friendly’ checklists based on the results of this study. All code used here is also provided to facilitate replication and adaptation by researchers and practitioners.
            
          , 
            Resumen
            El gran aumento en la cantidad de datos de biodiversidad generados a través de iniciativas de ciencia ciudadana, sumado al creciente número de productos de teledetección y herramientas para el modelado avanzado, ha abierto nuevas vías para monitorear de manera rápida, precisa y eficiente tendencias poblacionales de especies para informar políticas de conservación y gestión. Sin embargo, el aprovechamiento pleno e integración de estas diversas fuentes de datos y modelos sigue estando poco explorado, con esfuerzos a menudo concentrados en un número limitado de países desarrollados. En este estudio, i) resumimos dos décadas de datos de eBird en toda la isla de Irlanda y ii) combinamos cuatro años de datos con información de teledetección de alta resolución espacio‐temporal y modelos de ocupación jerárquica bayesianos para evaluar áreas ocupadas por las aves e identificar las variables ambientales que explican la ocurrencia, teniendo en cuenta la detección imperfecta. Aplicamos un modelo de ocupación multianual de una sola especie al mirlo euroasiático y un modelo multi‐especie y multianual a 14 especies, validando las predicciones del modelo utilizando un muestreo sistemático de aves. Los resultados muestran un aumento exponencial en la cantidad de listas subidas por usuarios a la plataforma de eBird entre los años 2002 and 2023. El modelo de una especie ajusto los datos de manera adecuada, incorporó varios sesgos en el proceso de observación y las predicciones en las áreas ocupadas presento alta precisión con un área bajo la curva de la característica operativa del receptor [AUC‐ROC] de 95.6\% a lo largo de los años. El modelo multi‐especie no ajusto a los datos y la precisión de las predicciones vario para las distintas especies y años: 14\% de las predicciones fueron pobres (AUC{\textless}60\%), 34\% regulares (AUC‐ROC 60‐70\%) y 77\% buenas (AUC‐ROC {\textgreater} 70\%). Si bien se necesitan más datos para mejorar el ajuste del modelo multi‐especies y para poder incluir especies menos abundantes en Irlanda, nuestros resultados resaltan el potencial de integrar los datos de ciencia ciudadana de eBird con imágenes de teledetección de alta resolución para mejorar los programas actuales de conservación, restauración y monitoreo de aves. Suponiendo que la participación de los ciudadanos y el número de listas subidas a la plataforma continúen con la tendencia creciente actual, la cobertura espacial y temporal de los datos mejorará, así como los resultados de los modelos. Para guiar este proceso, ofrecemos pautas para generar listas más "amigables para el análisis" basadas en los resultados de este estudio. Proporcionamos todo el código para facilitar la replicación y adaptación por parte de otros investigadores.},
	language = {en},
	urldate = {2026-03-18},
	journal = {Ibis},
	author = {Crego, Ramiro D. and Gobet, Solène and Kennedy, John and Burke, Brian and Lynch, Andrew and Coombes, Dick and Cummins, Sinéad and Lewis, Lesley},
